    <!-- Messages -->
    <mxCell id="m1" value="1. Onglet Mémoires → Clic sur étudiant → Rendre ma décision" style="html=1;endArrow=open;endFill=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="77" y="165" as="sourcePoint"/><mxPoint x="240" y="165" as="targetPoint"/></mxGeometry></mxCell>
    <mxCell id="m2" value="2. PATCH /api/encadrant/memoires/:etudiant_id/aptitude&#xa;   { aptitude, motif_refus, commentaire }" style="html=1;endArrow=open;endFill=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="240" y="210" as="sourcePoint"/><mxPoint x="435" y="210" as="targetPoint"/></mxGeometry></mxCell>
    <mxCell id="m3" value="3. verifierToken(JWT) + autoriserRoles('encadrant')" style="html=1;endArrow=open;endFill=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="435" y="255" as="sourcePoint"/><mxPoint x="645" y="255" as="targetPoint"/></mxGeometry></mxCell>
    <mxCell id="m4" value="4. deciderAptitude(req, res)" style="html=1;endArrow=open;endFill=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="435" y="295" as="sourcePoint"/><mxPoint x="645" y="295" as="targetPoint"/></mxGeometry></mxCell>
    <mxCell id="m5" value="5. findOne({ etudiant_id })" style="html=1;endArrow=open;endFill=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="645" y="335" as="sourcePoint"/><mxPoint x="860" y="335" as="targetPoint"/></mxGeometry></mxCell>
    <mxCell id="m6" value="6. SELECT * FROM memoires WHERE etudiant_id = ?" style="html=1;endArrow=open;endFill=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="860" y="375" as="sourcePoint"/><mxPoint x="1035" y="375" as="targetPoint"/></mxGeometry></mxCell>
    <mxCell id="m7" value="7. mémoire existant" style="html=1;endArrow=open;endFill=0;dashed=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1035" y="415" as="sourcePoint"/><mxPoint x="645" y="415" as="targetPoint"/></mxGeometry></mxCell>
    <mxCell id="m8" value="8. memoire.aptitude = req.body.aptitude&#xa;   memoire.motif_refus = req.body.motif_refus&#xa;   memoire.commentaire_encadrant = req.body.commentaire&#xa;   memoire.date_decision = new Date()" style="html=1;endArrow=none;endFill=0;fontSize=11;fillColor=#f5f5f5;strokeColor=none;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="660" y="455" as="sourcePoint"/><mxPoint x="850" y="455" as="targetPoint"/></mxGeometry></mxCell>
    <mxCell id="m9" value="9. save() → UPDATE memoires SET aptitude=?, date_decision=? WHERE id=?" style="html=1;endArrow=open;endFill=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="860" y="530" as="sourcePoint"/><mxPoint x="1035" y="530" as="targetPoint"/></mxGeometry></mxCell>
    <mxCell id="m10" value="10. { success: true, data: memoire, aptitude: 'apte'/'non_apte' }" style="html=1;endArrow=open;endFill=0;dashed=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="645" y="580" as="sourcePoint"/><mxPoint x="240" y="580" as="targetPoint"/></mxGeometry></mxCell>
    <mxCell id="m11" value="11. Toast ✓ 'Étudiant déclaré apte/non apte' + recharger liste" style="html=1;endArrow=open;endFill=0;dashed=1;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="240" y="620" as="sourcePoint"/><mxPoint x="77" y="620" as="targetPoint"/></mxGeometry></mxCell>

