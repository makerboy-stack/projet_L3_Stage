<mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0">
  <root>
    <mxCell id="0"/><mxCell id="1" parent="0"/>

    <mxCell id="titre" value="Cas d'Utilisation — Administrateur" style="text;html=1;align=center;fontStyle=1;fontSize=20;strokeColor=none;fillColor=none;" vertex="1" parent="1">
      <mxGeometry x="300" y="10" width="600" height="40" as="geometry"/>
    </mxCell>

    <mxCell id="sys" value="Système de Gestion des Stages &amp; Mémoires" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;strokeWidth=2;fontSize=13;fontStyle=1;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
      <mxGeometry x="210" y="65" width="900" height="700" as="geometry"/>
    </mxCell>

    <!-- Acteur bonhomme -->
    <mxCell id="adm" value="Administrateur" style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="60" y="360" width="60" height="90" as="geometry"/>
    </mxCell>

    <!-- Colonne 1 : Auth -->
    <mxCell id="uc1"  value="Se connecter"                              style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="240" y="90"  width="185" height="50" as="geometry"/></mxCell>
    <mxCell id="uc2"  value="Réinitialiser mot de passe"                style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="240" y="170" width="195" height="50" as="geometry"/></mxCell>

    <!-- Colonne 1 : Établissements -->
    <mxCell id="uc3"  value="Créer un établissement"                    style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="240" y="265" width="205" height="50" as="geometry"/></mxCell>
    <mxCell id="uc4"  value="Modifier un établissement"                 style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="240" y="345" width="205" height="50" as="geometry"/></mxCell>
    <mxCell id="uc5"  value="Activer / Masquer un établissement"        style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="240" y="425" width="215" height="50" as="geometry"/></mxCell>
    <mxCell id="uc6"  value="Supprimer un établissement"                style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="240" y="505" width="205" height="50" as="geometry"/></mxCell>
    <mxCell id="uc7"  value="Rechercher un établissement"               style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="240" y="585" width="215" height="50" as="geometry"/></mxCell>

    <!-- Colonne 2 : Structure académique -->
    <mxCell id="uc8"  value="Créer un département"                      style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="560" y="90"  width="200" height="50" as="geometry"/></mxCell>
    <mxCell id="uc9"  value="Modifier / Supprimer département"          style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="560" y="170" width="220" height="50" as="geometry"/></mxCell>
    <mxCell id="uc10" value="Créer une filière"                         style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="560" y="265" width="200" height="50" as="geometry"/></mxCell>
    <mxCell id="uc11" value="Modifier / Supprimer filière"              style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="560" y="345" width="215" height="50" as="geometry"/></mxCell>
    <mxCell id="uc12" value="Définir les niveaux d'une filière"         style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="560" y="425" width="220" height="50" as="geometry"/></mxCell>

    <!-- Colonne 3 : Comptes -->
    <mxCell id="uc13" value="Lister les comptes utilisateurs"           style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="890" y="90"  width="200" height="60" as="geometry"/></mxCell>
    <mxCell id="uc14" value="Activer / Désactiver un compte"            style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="890" y="185" width="200" height="50" as="geometry"/></mxCell>
    <mxCell id="uc15" value="Supprimer un compte"                       style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="890" y="265" width="195" height="50" as="geometry"/></mxCell>
    <mxCell id="uc16" value="Rechercher un utilisateur"                 style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="890" y="345" width="195" height="50" as="geometry"/></mxCell>
    <mxCell id="uc17" value="Filtrer par rôle ou statut"                style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="890" y="425" width="195" height="50" as="geometry"/></mxCell>
    <mxCell id="uc18" value="Consulter statistiques globales"           style="ellipse;whiteSpace=wrap;html=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="890" y="510" width="200" height="50" as="geometry"/></mxCell>

    <!-- Relations include/extend -->
    <mxCell id="i1" value="&lt;&lt;extend&gt;&gt;"  style="edgeStyle=none;dashed=1;html=1;fontSize=10;endArrow=open;" edge="1" source="uc8"  target="uc3"  parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="i2" value="&lt;&lt;extend&gt;&gt;"  style="edgeStyle=none;dashed=1;html=1;fontSize=10;endArrow=open;" edge="1" source="uc10" target="uc8"  parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="i3" value="&lt;&lt;include&gt;&gt;" style="edgeStyle=none;dashed=1;html=1;fontSize=10;endArrow=open;" edge="1" source="uc12" target="uc10" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="i4" value="&lt;&lt;include&gt;&gt;" style="edgeStyle=none;dashed=1;html=1;fontSize=10;endArrow=open;" edge="1" source="uc13" target="uc14" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="i5" value="&lt;&lt;include&gt;&gt;" style="edgeStyle=none;dashed=1;html=1;fontSize=10;endArrow=open;" edge="1" source="uc13" target="uc15" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

    <!-- Associations acteur → UC -->
    <mxCell id="a1"  edge="1" source="adm" target="uc1"  parent="1" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="a2"  edge="1" source="adm" target="uc2"  parent="1" style="html=1;endArrow=none;"><mxGeometry relative="1" as="geometry"/></mxCell>
