    <!-- Relations -->
    <mxCell id="i1" value="&lt;&lt;include&gt;&gt;" style="edgeStyle=none;dashed=1;html=1;fontSize=10;endArrow=open;" edge="1" source="uc7" target="uc6" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="i2" value="&lt;&lt;extend&gt;&gt;"  style="edgeStyle=none;dashed=1;html=1;fontSize=10;endArrow=open;" edge="1" source="uc8" target="uc6" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

